DirectoryIndex index.html
Options -Indexes

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  Header always set Strict-Transport-Security "max-age=31536000"

  <FilesMatch "\.html?$">
    Header always set Cache-Control "no-cache, must-revalidate, max-age=0"
  </FilesMatch>
  <FilesMatch "\.(css|js)$">
    Header always set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(avif|gif|jpe?g|png|svg|webp|woff2?)$">
    Header always set Cache-Control "public, max-age=2592000"
  </FilesMatch>
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On

  # One canonical host and HTTPS URL.
  RewriteCond %{HTTPS} !=on [OR]
  RewriteCond %{HTTP_HOST} ^www\.infiniteafricansafaris\.com$ [NC]
  RewriteRule ^ https://infiniteafricansafaris.com%{REQUEST_URI} [L,R=301]

  # Keep the homepage canonical instead of exposing /index.html.
  RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
  RewriteRule ^index\.html$ https://infiniteafricansafaris.com/ [L,R=301,QSD]
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json image/svg+xml
</IfModule>
